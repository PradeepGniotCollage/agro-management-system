# Project Settings
PROJECT_NAME="Jaiswal Khad Bhandar - Agro Management System"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=agro_db
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password@db:5432/agro_db

# Initial Admin Credentials
INITIAL_ADMIN_PHONE="9838000000"
INITIAL_ADMIN_PASSWORD="your_secure_pin"

# Security
SECRET_KEY=yoursecretkeyhere
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Sensor & Frontend
SERIAL_URL=
FRONTEND_URL="http://localhost:3000"

# Deployment Environment
# Set ENVIRONMENT=production on Vercel. Optionally, VERCEL=1 is auto-set.
ENVIRONMENT=development
VERCEL=

# Examples:
# - For local COM port: SERIAL_URL=COM4
# - For bridge socket: SERIAL_URL=socket://127.0.0.1:7777
